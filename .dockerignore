# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include embedded template files (compose YAML, init SQL, metadata)
!internal/templates/**/*.yml
!internal/templates/**/*.yaml
!internal/templates/**/*.sql

# Re-include embedded OpenAPI spec
!internal/api/openapi.yaml

# Re-include UI source for the build stage
!ui/package.json
!ui/package-lock.json
!ui/svelte.config.js
!ui/vite.config.ts
!ui/tsconfig.json
!ui/src/**
!ui/static/**
